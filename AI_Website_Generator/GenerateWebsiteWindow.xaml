<Window x:Class="Orak.WebPro.Admin.GenerateWebsiteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ORAK WebPro — Генерирай сайт"
        Width="620"
        Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#ECF0F1"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Margin" Value="0,12,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="18,14"
                Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.10"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="🌐 Генериране на уебсайт"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#2C3E50"/>
                <TextBlock x:Name="txtSubtitle"
                           Text="Попълнете данните и генерирайте готов за деплой сайт."
                           FontSize="13"
                           Foreground="#7F8C8D"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="18">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.10"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="НАИМЕНОВАНИЕ *" Style="{StaticResource SectionLabel}"/>
                    <TextBox x:Name="txtName"
                             Height="36"
                             Padding="10,6"
                             FontSize="14"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1"
                             Background="#FAFAFA"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="НАСЕЛЕНО МЯСТО *" Style="{StaticResource SectionLabel}"/>
                            <TextBox x:Name="txtCity"
                                     Height="36"
                                     Padding="10,6"
                                     FontSize="14"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     Background="#FAFAFA"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="АДРЕС" Style="{StaticResource SectionLabel}"/>
                            <TextBox x:Name="txtAddress"
                                     Height="36"
                                     Padding="10,6"
                                     FontSize="14"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     Background="#FAFAFA"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ИМЕЙЛ *" Style="{StaticResource SectionLabel}"/>
                            <TextBox x:Name="txtEmail"
                                     Height="36"
                                     Padding="10,6"
                                     FontSize="14"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     Background="#FAFAFA"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ТЕЛЕФОН" Style="{StaticResource SectionLabel}"/>
                            <TextBox x:Name="txtPhone"
                                     Height="36"
                                     Padding="10,6"
                                     FontSize="14"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     Background="#FAFAFA"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="МОЛ / ДИРЕКТОР" Style="{StaticResource SectionLabel}"/>
                            <TextBox x:Name="txtDirector"
                                     Height="36"
                                     Padding="10,6"
                                     FontSize="14"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     Background="#FAFAFA"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ДОМЕЙН" Style="{StaticResource SectionLabel}"/>
                            <TextBox x:Name="txtDomain"
                                     Height="36"
                                     Padding="10,6"
                                     FontSize="14"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     Background="#FAFAFA"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="МОТО / СЛОГАН" Style="{StaticResource SectionLabel}"/>
                    <TextBox x:Name="txtMotto"
                             Height="36"
                             Padding="10,6"
                             FontSize="14"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1"
                             Background="#FAFAFA"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ГОДИНА ОСНОВАВАНЕ" Style="{StaticResource SectionLabel}"/>
                            <TextBox x:Name="txtFounded"
                                     Height="36"
                                     Padding="10,6"
                                     FontSize="14"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     Background="#FAFAFA"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="БРОЙ УЧЕНИЦИ" Style="{StaticResource SectionLabel}"/>
                            <TextBox x:Name="txtStudents"
                                     Height="36"
                                     Padding="10,6"
                                     FontSize="14"
                                     BorderBrush="#BDC3C7"
                                     BorderThickness="1"
                                     Background="#FAFAFA"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="ТИП ШАБЛОН *" Style="{StaticResource SectionLabel}"/>
                    <ComboBox x:Name="cmbTemplate"
                              Height="36"
                              Padding="10,6"
                              FontSize="14"
                              BorderBrush="#BDC3C7"
                              BorderThickness="1"
                              Background="#FAFAFA">
                        <ComboBoxItem Content="🏫  Шаблон Б — Училище" Tag="School"/>
                        <ComboBoxItem Content="🎓  Шаблон А — Университет" Tag="University"/>
                        <ComboBoxItem Content="🧸  Шаблон В — Детска градина" Tag="Kindergarten"/>
                    </ComboBox>

                    <TextBlock Text="ОСНОВЕН ЦВЯТ" Style="{StaticResource SectionLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                x:Name="colorPreview"
                                Width="36"
                                Height="36"
                                CornerRadius="8"
                                Background="#1B4D3E"
                                BorderBrush="#BDC3C7"
                                BorderThickness="1"
                                Cursor="Hand"
                                MouseLeftButtonDown="ColorPreview_Click">
                            <Border.ToolTip>Кликнете за избор на цвят</Border.ToolTip>
                        </Border>

                        <TextBox Grid.Column="2"
                                 x:Name="txtColor"
                                 Height="36"
                                 Padding="10,6"
                                 FontSize="14"
                                 Text="#1B4D3E"
                                 BorderBrush="#BDC3C7"
                                 BorderThickness="1"
                                 Background="#FAFAFA"
                                 TextChanged="txtColor_TextChanged"/>
                    </Grid>

                    <TextBlock Text="ПАПКА ЗА ИЗХОД" Style="{StaticResource SectionLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 x:Name="txtOutputFolder"
                                 Height="36"
                                 Padding="10,6"
                                 FontSize="13"
                                 Text="C:\OrakSites\generated\"
                                 BorderBrush="#BDC3C7"
                                 BorderThickness="1"
                                 Background="#FAFAFA"/>

                        <Button Grid.Column="2"
                                Content="📁"
                                Height="36"
                                Width="40"
                                FontSize="16"
                                Click="BrowseOutput_Click"
                                Background="White"
                                BorderBrush="#BDC3C7"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="10"
                    Padding="12,8">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.08"/>
                </Border.Effect>
                <TextBlock x:Name="txtStatus"
                           Text="Готов за генериране."
                           FontSize="13"
                           Foreground="#5D6D7E"
                           VerticalAlignment="Center"/>
            </Border>

            <Button Grid.Column="2"
                    x:Name="btnGenerate"
                    Content="🚀  Генерирай сайт"
                    Height="44"
                    Padding="22,0"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="White"
                    Background="#27AE60"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnGenerate_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>

                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#229954"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#95A5A6"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>