<Window x:Class="Orak.WebPro.Admin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Orak.WebPro.Admin"
        Title="ORAK WebPro"
        WindowState="Maximized"
        Background="#ECF0F1"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!--<local:ChatBubbleColorMultiConverter x:Key="ChatBubbleColorMultiConverter"/>
        <local:ChatAlignmentConverter x:Key="ChatAlignmentConverter"/>-->

        <DataTemplate x:Key="ChatMessageTemplate">
            <Border CornerRadius="10"
                    Padding="10"
                    Margin="5"
                    MaxWidth="520"
                    HorizontalAlignment="{Binding IsMe, Converter={StaticResource ChatAlignmentConverter}}">
                <Border.Background>
                    <MultiBinding Converter="{StaticResource ChatBubbleColorMultiConverter}">
                        <Binding Path="IsMe"/>
                        <Binding Path="IsLatest"/>
                    </MultiBinding>
                </Border.Background>

                <StackPanel>
                    <TextBlock Text="{Binding Message}"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="#2C3E50"/>

                    <TextBlock Text="{Binding Time}"
                               FontSize="10"
                               Foreground="#7F8C8D"
                               HorizontalAlignment="Right"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <Style x:Key="SidebarButtonBase" TargetType="Button">
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource SidebarButtonBase}">
            <Setter Property="Background" Value="#3498DB"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarButtonAlt" TargetType="Button" BasedOn="{StaticResource SidebarButtonBase}">
            <Setter Property="Background" Value="#9B59B6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8E44AD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarButtonGreen" TargetType="Button" BasedOn="{StaticResource SidebarButtonBase}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#229954"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Width" Value="260"/>
            <Setter Property="Height" Value="115"/>
            <Setter Property="BorderBrush" Value="#EEF2F5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.18"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopChip" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#E6ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.12"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0B5394"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#073763"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryActionButtonLight" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
            <Setter Property="Background" Value="#1F6FB2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#165A8F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarBottomCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Background" Value="#253646"/>
            <Setter Property="BorderBrush" Value="#3B556A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="6,10,6,6"/>
        </Style>

        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderBrush" Value="#E6ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="10" Opacity="0.10"/>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#2C3E50" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,6,0,10">
                    <TextBlock Text="📌 ORAK WebPro"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="8,0,8,10"/>
                    <Separator Background="#95A5A6" Height="1" Margin="8,0,8,10"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Content="➕ Нов клиент / проект" Click="AddNewDomain_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="🌍 Уебсайтове" Click="OpenDomainList_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="📜 Заявки" Click="btnViewRequests_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="🎨 Одобрени дизайни / темплейти" Click="btnManageDesigns_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="🛠️ Поддръжка и мониторинг" Click="btnTechSupport_Click" Style="{StaticResource SidebarButton}" />
                    <Button Content="👥 Екип и роли" Click="btnManageTeam_Click" Style="{StaticResource SidebarButtonAlt}" />
                    <Button Content="📊 AI анализ" Click="OpenWebsiteStatistics_Click" Style="{StaticResource SidebarButtonGreen}" />
                </StackPanel>

                <Border Grid.Row="2" Style="{StaticResource SidebarBottomCard}">
                    <StackPanel>
                        <TextBlock Text="🤖 AI помощник"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="2,0,2,6"/>
                        <TextBlock Text="Бърз достъп до помощ, идеи и насоки."
                                   Foreground="#C9D6E2"
                                   FontSize="12"
                                   Margin="2,0,2,10"/>
                        <Button Content="Отвори асистента"
                                Click="OpenChatbotWindow_Click"
                                Style="{StaticResource SidebarButtonGreen}"
                                Margin="0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1">
            <Border Background="White" Padding="22" CornerRadius="14" Margin="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- user info -->
                    <Border Grid.Row="0"
                            Style="{StaticResource TopChip}"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="30" Height="30" Fill="#95A5A6"/>
                            <TextBlock Text="{Binding CurrentUsername}"
                                       FontWeight="Bold"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#2C3E50"/>
                        </StackPanel>
                    </Border>

                    <!-- header -->
                    <StackPanel Grid.Row="1" Margin="2,0,2,14">
                        <TextBlock Text="👋 Добре дошли в ORAK WebPro"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Платформа за вътрешно управление на заявки, изграждане, пускане и поддръжка на клиентски уебсайтове."
                                   FontSize="16"
                                   Foreground="#34495E"/>
                    </StackPanel>

                    <!-- top stats -->
                    <UniformGrid Grid.Row="2" Columns="4" Margin="0,10,0,18">
                        <Border Style="{StaticResource DashboardCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="📥 Нови заявки"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#2C3E50"/>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding NewRequestsCount, FallbackValue=6}"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           Foreground="#2980B9"
                                           VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource DashboardCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="🧩 Сайтове в изработка"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#2C3E50"/>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding WebsitesInBuildCount, FallbackValue=8}"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           Foreground="#E67E22"
                                           VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource DashboardCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="🚀 Пуснати уебсайтове"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#2C3E50"/>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding LiveWebsitesCount, FallbackValue=12}"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           Foreground="#27AE60"
                                           VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource DashboardCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="⚠️ Нуждаят се от внимание"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#2C3E50"/>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding AttentionItemsCount, FallbackValue=3}"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           Foreground="#C0392B"
                                           VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>
                    </UniformGrid>

                    <!-- bottom panels -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- workflow -->
                        <Border Grid.Column="0" Style="{StaticResource PanelCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="📌 Работен поток"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#2C3E50"/>
                                    <TextBlock Text="Текущите основни стъпки по клиентските уеб проекти."
                                               FontSize="13"
                                               Foreground="#5D6D7E"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Background="#F7FAFC"
                                        BorderBrush="#E6ECEF"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="✅ Препоръчани действия"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="#2C3E50"
                                                   Margin="0,0,0,8"/>

                                        <TextBlock Text="• Прегледай новите заявки и ги разпредели по отговорници."
                                                   Foreground="#34495E"
                                                   FontSize="13"
                                                   Margin="0,0,0,5"/>
                                        <TextBlock Text="• Провери кои проекти чакат одобрение на дизайн."
                                                   Foreground="#34495E"
                                                   FontSize="13"
                                                   Margin="0,0,0,5"/>
                                        <TextBlock Text="• Отвори сайтовете в изработка и обнови текущ етап."
                                                   Foreground="#34495E"
                                                   FontSize="13"
                                                   Margin="0,0,0,5"/>
                                        <TextBlock Text="• Подготви сайтовете за качване в CMS системата."
                                                   Foreground="#34495E"
                                                   FontSize="13"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Row="2" Margin="0,14,0,0">
                                    <Border Background="#EAF6FF" BorderBrush="#BFDFF5" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                                        <DockPanel>
                                            <TextBlock Text="1." FontWeight="Bold" Foreground="#0B4A74" Margin="0,0,10,0"/>
                                            <TextBlock Text="Нова заявка / клиентско запитване" Foreground="#0B4A74" VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>

                                    <Border Background="#FFF3E6" BorderBrush="#F2D6B3" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                                        <DockPanel>
                                            <TextBlock Text="2." FontWeight="Bold" Foreground="#8E5A00" Margin="0,0,10,0"/>
                                            <TextBlock Text="Избор и одобрение на дизайн / темплейт" Foreground="#8E5A00" VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>

                                    <Border Background="#EFFFF3" BorderBrush="#BFE8C8" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                                        <DockPanel>
                                            <TextBlock Text="3." FontWeight="Bold" Foreground="#1E6B3A" Margin="0,0,10,0"/>
                                            <TextBlock Text="Изработка и подготовка за CMS качване" Foreground="#1E6B3A" VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>

                                    <Border Background="#F5ECFF" BorderBrush="#D8C3F0" BorderThickness="1" CornerRadius="10" Padding="12">
                                        <DockPanel>
                                            <TextBlock Text="4." FontWeight="Bold" Foreground="#6C3483" Margin="0,0,10,0"/>
                                            <TextBlock Text="Пускане, мониторинг и поддръжка" Foreground="#6C3483" VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>
                                </StackPanel>

                                <UniformGrid Grid.Row="3" Columns="2" Margin="30,20,30,0">
                                    <Button Content="Отвори заявки"
                                            Click="btnViewRequests_Click"
                                            Style="{StaticResource PrimaryActionButton}"
                                            Margin="0,0,8,0"/>

                                    <Button Content="Темплейти / дизайни"
                                            Click="btnManageDesigns_Click"
                                            Style="{StaticResource PrimaryActionButtonLight}"
                                            Margin="0,0,8,0"/>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <!-- health / deployment -->
                        <Border Grid.Column="2" Style="{StaticResource PanelCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="🛡 CMS / Пускане / Мониторинг"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#2C3E50"/>
                                    <TextBlock Text="Статус на качвания, домейни, SSL и поддръжка."
                                               FontSize="13"
                                               Foreground="#5D6D7E"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                    <Border Background="#EFFFF3" BorderBrush="#BFE8C8" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                                        <DockPanel LastChildFill="False">
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="✅ CMS качвания" FontWeight="Bold" Foreground="#1E6B3A"/>
                                                <TextBlock Text="Последно качване: успешно" Foreground="#1E6B3A" FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Text="преди 10 мин"
                                                       Foreground="#1E6B3A"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </DockPanel>
                                    </Border>

                                    <Border Background="#EAF6FF" BorderBrush="#BFDFF5" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                                        <DockPanel LastChildFill="False">
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="✅ Домейни и DNS" FontWeight="Bold" Foreground="#0B4A74"/>
                                                <TextBlock Text="Активните сайтове са свързани коректно" Foreground="#0B4A74" FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Text="актуално"
                                                       Foreground="#0B4A74"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </DockPanel>
                                    </Border>

                                    <Border Background="#FFF3E6" BorderBrush="#F2D6B3" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                                        <DockPanel LastChildFill="False">
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="⚠️ SSL сертификати" FontWeight="Bold" Foreground="#8E5A00"/>
                                                <TextBlock Text="1 сайт изисква подновяване скоро" Foreground="#8E5A00" FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Text="внимание"
                                                       Foreground="#8E5A00"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </DockPanel>
                                    </Border>

                                    <Border Background="#FFECEC" BorderBrush="#F3BABA" BorderThickness="1" CornerRadius="10" Padding="12">
                                        <DockPanel LastChildFill="False">
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="🛠️ Поддръжка" FontWeight="Bold" Foreground="#8B1E1E"/>
                                                <TextBlock Text="Има 2 активни сигнала от клиенти" Foreground="#8B1E1E" FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Text="отворени"
                                                       Foreground="#8B1E1E"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </DockPanel>
                                    </Border>
                                </StackPanel>

                                <Grid Grid.Row="2"/>

                                <UniformGrid Grid.Row="3" Columns="2" Margin="30,20,30,0">
                                    <Button Content="Уебсайтове"
                                            Click="OpenDomainList_Click"
                                            Style="{StaticResource PrimaryActionButton}"
                                            Margin="0,0,8,0"/>

                                    <Button Content="Поддръжка"
                                            Click="btnTechSupport_Click"
                                            Style="{StaticResource PrimaryActionButtonLight}"
                                            Margin="0,0,8,0"/>
                                </UniformGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Image Source="images/Orak-Academy-Logo-Remake-2024.png"
                   Width="180"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="18"
                   Opacity="0.9"
                   IsHitTestVisible="False"
                   Panel.ZIndex="-1"/>
        </Grid>
    </Grid>
</Window>